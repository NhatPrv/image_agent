# ═══════════════════════════════════════════
# Image Agent — Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# ─── App ───
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG

# ─── Server ───
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# ─── Paths ───
# Leave empty to use defaults (relative to project root)
MODELS_DIR=
OUTPUTS_DIR=
DATABASE_PATH=

# ─── GPU ───
# Options: cuda, cpu, auto (default: auto)
GPU_DEVICE=auto
# Options: float16, float32, bfloat16 (default: float16)
GPU_DTYPE=float16
# Enable xformers memory-efficient attention (default: true)
GPU_XFORMERS=true

# ─── Generation Defaults ───
DEFAULT_STEPS=20
DEFAULT_CFG_SCALE=7.0
DEFAULT_WIDTH=512
DEFAULT_HEIGHT=512
DEFAULT_SAMPLER=euler_a
